<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ninisoul_background"
    tools:context=".AddRecipeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- same green header style, keeping it consistent across every screen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/ninisoul_green"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NiniSoul"
                android:textColor="@color/ninisoul_green_light"
                android:textSize="13sp"
                android:alpha="0.85" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Add a Recipe"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- form fields go here, each wrapped in its own card to match the rest of my app's style -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recipe Photo (optional)"
                android:textColor="@color/ninisoul_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_photo_picker"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/ninisoul_green_light">

                <!-- this shows the selected photo once the user picks one -->
                <ImageView
                    android:id="@+id/iv_selected_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- this is the "tap to add photo" placeholder, hidden once a photo is picked -->
                <TextView
                    android:id="@+id/tv_add_photo_hint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Tap to add a photo"
                    android:textColor="@color/ninisoul_green"
                    android:textStyle="bold"
                    android:textSize="15sp" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recipe Name"
                android:textColor="@color/ninisoul_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <EditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:hint="e.g. Cucu's Mukimo"
                    android:textColor="@color/ninisoul_text_dark"
                    android:textSize="16sp"
                    android:background="@android:color/transparent" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ingredients"
                android:textColor="@color/ninisoul_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <EditText
                    android:id="@+id/et_ingredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:hint="List each ingredient with measurements"
                    android:textSize="16sp"
                    android:background="@android:color/transparent" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cooking Steps"
                android:textColor="@color/ninisoul_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <EditText
                    android:id="@+id/et_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:minLines="4"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:hint="Write out the cooking method step by step"
                    android:textSize="16sp"
                    android:background="@android:color/transparent" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tag (optional)"
                android:textColor="@color/ninisoul_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <EditText
                    android:id="@+id/et_tag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:hint="e.g. Mum's Recipe, Cucu's Recipe"
                    android:textSize="16sp"
                    android:background="@android:color/transparent" />

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_save_recipe"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Recipe"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/ninisoul_orange" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>