<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ninisoul_background"
    tools:context=".MealDeciderFragment">

    <!-- Small header band up top, just the brand tag + page title and reset action -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/ninisoul_green"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NiniSoul"
            android:textColor="@color/ninisoul_green_light"
            android:textSize="13sp"
            android:alpha="0.85" />

        <!-- RelativeLayout lets us place the Title and Reset text side-by-side cleanly -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Leo Tutakula Nini?"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- NEW RESET ACTION LINK -->
            <TextView
                android:id="@+id/tv_reset_filters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:text="Reset Filters"
                android:textColor="@color/ninisoul_green_light"
                android:textSize="13sp"
                android:textStyle="bold"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackground" />

        </RelativeLayout>

    </LinearLayout>

    <!-- photo area sits directly below the header -->
    <FrameLayout
        android:id="@+id/photo_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:background="@color/ninisoul_green_light"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_card"
        app:layout_constraintHeight_percent="0.55">

        <ImageView
            android:id="@+id/iv_meal_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/badge_pill_background"
            android:text="Surprise Pick"
            android:textColor="@color/ninisoul_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp" />

        <TextView
            android:id="@+id/tv_meal_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="20dp"
            android:text="Tap the button below"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/photo_area"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_meal_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/ninisoul_text_gray"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        <!-- ACTION ROW: Clean side-by-side action controls -->
        <LinearLayout
            android:id="@+id/layout_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <!-- Don't Suggest Button -->
            <Button
                android:id="@+id/btn_block_meal"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Don't Suggest"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#A33226" />

            <!-- Pick This Meal Button -->
            <Button
                android:id="@+id/btn_pick_meal"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Pick This Meal"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="@color/ninisoul_green" />

        </LinearLayout>

        <!-- Shuffle Button -->
        <Button
            android:id="@+id/btn_decide"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Decide a meal"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:backgroundTint="#E65F2B" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>